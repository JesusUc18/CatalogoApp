@model List<CatalogoApp.Domain.Models.Item>
@{
    ViewData["Title"] = "Catálogo";
}

<h1>Catálogo de Videojuegos</h1>
<p style="color:var(--color-texto-muted);margin-bottom:0.5rem;">Explora nuestra colección</p>

<!-- Filtros por Género -->
<div class="filtros">
    <a asp-action="Index" class="filtro-btn @(ViewBag.GeneroActual == null ? "activo" : "")">Todos</a>
    @foreach (var gen in ViewBag.Generos as List<string>)
    {
        <a asp-action="Index" asp-route-genero="@gen"
           class="filtro-btn @(ViewBag.GeneroActual == gen ? "activo" : "")">@gen</a>
    }
</div>

<!-- Botón agregar (solo logueado) -->
@if (ViewBag.UsuarioLogueado != null)
{
    <a asp-action="Agregar" class="btn btn-primary" style="margin-bottom:1.2rem;">+ Agregar videojuego</a>
}
else
{
    <p style="font-size:0.88rem;color:var(--color-texto-muted);margin-bottom:1rem;">
        <a asp-controller="Usuario" asp-action="Login">Inicia sesión</a> para agregar videojuegos.
    </p>
}

<hr />

<!-- Grid de juegos -->
@if (Model.Count == 0)
{
    <div class="empty-state">
        <div class="icon">🎮</div>
        <p>No hay videojuegos en esta categoría.</p>
    </div>
}
else
{
    <div class="catalogo-grid">
        @foreach (var item in Model)
        {
            <div class="juego-card">
                @if (!string.IsNullOrEmpty(item.ImagenUrl))
                {
                    <a asp-action="Detalle" asp-route-id="@item.Id">
                        <img src="@item.ImagenUrl" alt="@item.Titulo"
                             style="width:100%;height:auto;object-fit:contain;border-radius:8px;margin-bottom:0.8rem;" />
                    </a>
                }
                <h3><a asp-action="Detalle" asp-route-id="@item.Id">@item.Titulo</a></h3>
                <div class="juego-meta">
                    <span class="badge-genero">@item.Genero</span>
                    <span class="badge-ano">@item.Ano</span>
                </div>
                <p style="color:var(--color-texto-muted);font-size:0.85rem;margin-top:0.7rem;margin-bottom:0;">
                    @item.Consola
                </p>
            </div>
        }
    </div>
}